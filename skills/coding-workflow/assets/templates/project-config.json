{
  "name": "project-name",
  "version": "1.0.0",
  "commands": {
    "dev": "npm run dev",
    "build": "npm run build",
    "lint": "npm run lint",
    "test": "npm run test"
  },
  "testing": {
    "browser_required_for": [
      "new_pages",
      "major_ui_changes",
      "form_submissions",
      "interactive_features"
    ],
    "lint_required": true,
    "build_required": true
  },
  "commit": {
    "include_files": [
      "task.json",
      "progress.txt"
    ],
    "message_format": "[Task Title] - completed"
  },
  "blocking": {
    "stop_on_block": true,
    "require_human_confirmation": [
      "api_keys",
      "database_setup",
      "external_services"
    ]
  }
}
